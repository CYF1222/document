\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{myformat}[2025/03/13 v1.0 Custom format for mathematical modeling]

% ---------- 宏包加载 ----------
\RequirePackage{titlesec}       % 自定义标题格式
\RequirePackage{diagbox}        % 绘制斜线
\RequirePackage{amsmath,amssymb,amsfonts}
\RequirePackage{graphicx}       % 插图
\RequirePackage{geometry}       % 页面设置
\RequirePackage{tabularx}       % 自适应宽度表格
\RequirePackage{booktabs}       % 美观表格线条
\RequirePackage{multirow}       % 合并单元格
\RequirePackage{setspace}       % 行距设置
\RequirePackage{tocloft}        % 目录格式
\RequirePackage{comment}        % 多行注释
\RequirePackage{titling}        % 修改标题行为
\RequirePackage{array}          % 增强表格
\RequirePackage{minted}         % 代码高亮
\RequirePackage{wrapfig}        % 图文绕排
\RequirePackage{caption}        % 标题格式
\RequirePackage{lipsum}         % 示例文本
\RequirePackage{stmaryrd}       % 粗箭头符号
\RequirePackage{float}          % 固定位置 [H]
\RequirePackage{fancyhdr}       % 自定义页眉页脚
\RequirePackage{enumitem}       % 自定义列表
\RequirePackage{pgfplots}       % 绘图
\pgfplotsset{compat=1.17}
\RequirePackage{xcolor}         % 颜色
\RequirePackage{tikz}            % TikZ 绘图
\RequirePackage{markdown}
\usetikzlibrary{shapes.geometric, arrows.meta, bending, fadings, backgrounds}

% ---------- 自定义图层 ----------
\pgfdeclarelayer{toplayer}
\pgfsetlayers{main, toplayer}

% ---------- 颜色定义 ----------
\definecolor{lightblue}{RGB}{173,216,230}

% ---------- 代码环境设置 ----------
\setminted{
    frame=single,
    bgcolor=white,
    fontsize=\small,
    breaklines=true,
    encoding=utf8
}

% ---------- 页面几何 ----------
\geometry{a4paper, margin=2.5cm}

% ---------- 重定义标题 ----------
\makeatletter
\def\maketitle{%
    \begin{center}
      \heiti \bfseries \fontsize{22pt}{26.4pt}%
      《数学建模基础创新实践{\fontsize{22pt}{26.4pt}\selectfont1}》
    \end{center}
}
\makeatother

% ---------- 章节标题格式 ----------
\titleformat{\section}
  {\centering\Large\bfseries}
  {\chinese{section}、}
  {0.5em}
  {}

\titleformat{\subsection}[block]
  {\Large\bfseries}
  {\arabic{section}.\arabic{subsection}}
  {0.5em}
  {}

\titleformat{\subsubsection}
  {\large\bfseries}
  {\thesubsubsection}
  {1em}
  {}

% ---------- 页眉页脚 ----------
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\cfoot{\thepage}

\fancypagestyle{plain}{
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \cfoot{\thepage}
}

% ---------- 摘要标题 ----------
\renewcommand{\abstractname}{%
  \begin{center}
    \bfseries \heiti \fontsize{14pt}{16.8pt} 摘要
  \end{center}
}

% ---------- 文档默认字体设置 ----------
\AtBeginDocument{%
  \zihao{-4}%
  \songti%
  \linespread{1.0}%
  \selectfont%
}

\endinput